import React, { useState, useEffect, useRef } from 'react';
import api from '../services/api';

export default function Conversations() {
  const [conversations, setConversations] = useState([]);
  const [selected, setSelected] = useState(null);
  const [messages, setMessages] = useState([]);
  const [notes, setNotes] = useState([]);
  const [tags, setTags] = useState([]);
  const [globalTags, setGlobalTags] = useState([]);
  const [replyMode, setReplyMode] = useState('ai');
  const [newMsg, setNewMsg] = useState('');
  const [newNote, setNewNote] = useState('');
  const [newTag, setNewTag] = useState('');
  const [suggestions, setSuggestions] = useState([]);
  const [activeTab, setActiveTab] = useState('notes');
  const [drawerOpen, setDrawerOpen] = useState(false);
  const messagesEnd = useRef(null);

  useEffect(() => {
    fetchConversations();
  }, []);

  const fetchConversations = async () => {
    const res = await api.get('/api/conversations');
    setConversations(res.data);
  };

  const fetchMessages = async (id) => {
    const res = await api.get(`/api/conversations/${id}/messages`);
    setMessages(res.data);
    messagesEnd.current?.scrollIntoView({ behavior: 'smooth' });
  };

  const fetchNotes = async (id) => {
    const res = await api.get(`/api/conversations/${id}/notes`);
    setNotes(res.data);
  };

  const fetchTags = async (id) => {
    const res = await api.get(`/api/conversations/${id}/tags`);
    setTags(res.data);
  };

  const fetchGlobalTags = async () => {
    const res = await api.get('/api/conversations/tags');
    setGlobalTags(res.data);
  };

  const selectConversation = async (conv) => {
    setSelected(conv);
    await fetchMessages(conv.id);
    await fetchNotes(conv.id);
    await fetchTags(conv.id);
    await fetchGlobalTags();
    setReplyMode(conv.reply_mode || 'ai');
  };

  const sendMessage = async () => {
    if (!newMsg.trim()) return;
    await api.post(`/api/conversations/${selected.id}/send`, { text: newMsg, sender_type: 'agent' });
    setNewMsg('');
    await fetchMessages(selected.id);
  };

  const addNote = async () => {
    if (!newNote.trim()) return;
    await api.post(`/api/conversations/${selected.id}/notes`, { note: newNote });
    setNewNote('');
    await fetchNotes(selected.id);
  };

  const deleteNote = async (id) => {
    await api.delete(`/api/conversations/notes/${id}`);
    await fetchNotes(selected.id);
  };

  const createTag = async (name) => {
    const res = await api.post('/api/conversations/tags', { name });
    setGlobalTags([...globalTags, res.data]);
    return res.data;
  };

  const attachTag = async (tagId) => {
    await api.post(`/api/conversations/${selected.id}/tags/${tagId}`);
    await fetchTags(selected.id);
  };

  const detachTag = async (tagId) => {
    await api.delete(`/api/conversations/${selected.id}/tags/${tagId}`);
    await fetchTags(selected.id);
  };

  const toggleMode = async () => {
    const newMode = replyMode === 'ai' ? 'human' : 'ai';
    await api.patch(`/api/conversations/${selected.id}/mode?mode=${newMode}`);
    setReplyMode(newMode);
  };

  useEffect(() => {
    if (newTag.length > 0) {
      const filtered = globalTags.filter(t => t.name.toLowerCase().includes(newTag.toLowerCase()) && !tags.some(tt => tt.id === t.id));
      setSuggestions(filtered);
    } else {
      setSuggestions([]);
    }
  }, [newTag, globalTags, tags]);

  if (!conversations.length) return <div className="p-6">Loading conversations...</div>;

  return (
    <div className="flex h-screen bg-gray-100">
      <div className="w-80 bg-white border-r flex flex-col">
        <div className="p-4 border-b"><h2 className="text-xl font-bold">Conversations</h2></div>
        <div className="flex-1 overflow-y-auto">
          {conversations.map(conv => (
            <div key={conv.id} onClick={() => selectConversation(conv)} className={`p-3 border-b cursor-pointer hover:bg-gray-50 ${selected?.id === conv.id ? 'bg-indigo-50' : ''}`}>
              <div className="font-medium">{conv.customer_name || conv.customer_phone_number}</div>
              <div className="text-sm text-gray-500 truncate">{conv.last_message}</div>
              <div className="flex justify-between mt-1">
                <span className={`text-xs px-2 py-0.5 rounded-full ${conv.reply_mode === 'ai' ? 'bg-amber-100' : 'bg-green-100'}`}>
                  {conv.reply_mode === 'ai' ? 'AI' : 'Human'}
                </span>
                {conv.unread_count > 0 && <span className="bg-indigo-500 text-white text-xs px-2 rounded-full">{conv.unread_count}</span>}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div className="flex-1 flex flex-col">
        {selected ? (
          <>
            <div className="bg-white border-b px-6 py-3 flex justify-between items-center">
              <div>
                <h3 className="font-semibold">{selected.customer_name || selected.customer_phone_number}</h3>
                <div className="flex flex-wrap gap-1 mt-1">
                  {tags.map(tag => <span key={tag.id} className="bg-indigo-100 text-indigo-800 text-xs px-2 py-0.5 rounded-full">{tag.name}</span>)}
                </div>
              </div>
              <div className="flex gap-2">
                <button onClick={toggleMode} className={`px-3 py-1 rounded-full text-sm ${replyMode === 'ai' ? 'bg-amber-100' : 'bg-green-100'}`}>
                  {replyMode === 'ai' ? '🤖 AI' : '👤 Human'}
                </button>
                <button onClick={() => setDrawerOpen(true)} className="p-2 rounded-full hover:bg-gray-100">📝</button>
              </div>
            </div>
            <div className="flex-1 overflow-y-auto p-4 space-y-2">
              {messages.map(msg => (
                <div key={msg.id} className={`flex ${msg.direction === 'outbound' ? 'justify-end' : 'justify-start'}`}>
                  <div className={`max-w-xs px-4 py-2 rounded-2xl ${msg.direction === 'outbound' ? 'bg-indigo-500 text-white' : 'bg-white border'}`}>
                    {msg.content}
                    <div className="text-xs opacity-70 mt-1">{new Date(msg.created_at).toLocaleTimeString()}</div>
                  </div>
                </div>
              ))}
              <div ref={messagesEnd} />
            </div>
            <div className="bg-white border-t p-4 flex gap-2">
              <input type="text" value={newMsg} onChange={e => setNewMsg(e.target.value)} onKeyPress={e => e.key === 'Enter' && sendMessage()} placeholder="Type a message..." className="flex-1 border rounded-full px-4 py-2" />
              <button onClick={sendMessage} className="bg-indigo-600 text-white px-4 py-2 rounded-full">Send</button>
            </div>
          </>
        ) : <div className="flex items-center justify-center h-full text-gray-400">Select a conversation</div>}
      </div>

      {drawerOpen && (
        <div className="fixed inset-0 z-50 flex justify-end">
          <div className="absolute inset-0 bg-black bg-opacity-50" onClick={() => setDrawerOpen(false)} />
          <div className="relative w-80 bg-white h-full shadow-xl flex flex-col">
            <div className="flex border-b">
              <button onClick={() => setActiveTab('notes')} className={`flex-1 py-3 text-center ${activeTab === 'notes' ? 'text-indigo-600 border-b-2' : 'text-gray-500'}`}>Notes</button>
              <button onClick={() => setActiveTab('tags')} className={`flex-1 py-3 text-center ${activeTab === 'tags' ? 'text-indigo-600 border-b-2' : 'text-gray-500'}`}>Tags</button>
            </div>
            <div className="flex-1 overflow-y-auto p-4">
              {activeTab === 'notes' ? (
                <div>
                  {notes.map(n => (
                    <div key={n.id} className="bg-gray-50 p-3 rounded-lg relative mb-2">
                      <p className="text-sm">{n.note}</p>
                      <div className="text-xs text-gray-400">{new Date(n.created_at).toLocaleString()}</div>
                      <button onClick={() => deleteNote(n.id)} className="absolute top-2 right-2 text-red-400 text-xs">✕</button>
                    </div>
                  ))}
                  <textarea value={newNote} onChange={e => setNewNote(e.target.value)} rows="2" className="w-full border rounded-lg p-2" placeholder="Add a private note..." />
                  <button onClick={addNote} className="mt-2 w-full bg-indigo-600 text-white py-1 rounded-lg">Add Note</button>
                </div>
              ) : (
                <div>
                  <div className="flex flex-wrap gap-2 mb-4">
                    {tags.map(tag => (
                      <div key={tag.id} className="bg-indigo-100 text-indigo-800 px-2 py-1 rounded-full flex items-center gap-1">
                        {tag.name}
                        <button onClick={() => detachTag(tag.id)} className="text-red-500 text-xs">✕</button>
                      </div>
                    ))}
                  </div>
                  <input type="text" value={newTag} onChange={e => setNewTag(e.target.value)} placeholder="Add tag (#urgent)" className="w-full border rounded-lg p-2" />
                  {suggestions.length > 0 && (
                    <div className="absolute z-10 w-72 bg-white border rounded-lg mt-1 max-h-32 overflow-y-auto">
                      {suggestions.map(t => (
                        <div key={t.id} onClick={() => { attachTag(t.id); setNewTag(''); }} className="p-2 hover:bg-gray-100 cursor-pointer">{t.name}</div>
                      ))}
                    </div>
                  )}
                  <button onClick={async () => {
                    if (!newTag.trim()) return;
                    const existing = globalTags.find(t => t.name.toLowerCase() === newTag.trim().toLowerCase());
                    if (existing) await attachTag(existing.id);
                    else { const newT = await createTag(newTag.trim()); await attachTag(newT.id); }
                    setNewTag('');
                  }} className="mt-2 w-full bg-indigo-600 text-white py-1 rounded-lg">Add Tag</button>
                </div>
              )}
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
